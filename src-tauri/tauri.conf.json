{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Companion",
  "version": "0.1.0",
  "identifier": "dev.ben4mn.claude-companion",
  "build": {
    "frontendDist": "../src",
    "devUrl": null
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "companion",
        "title": "Claude Companion",
        "width": 120,
        "height": 160,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "acceptFirstMouse": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
