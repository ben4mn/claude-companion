{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Companion",
  "version": "0.1.0",
  "identifier": "dev.ben4mn.companion",
  "build": {
    "frontendDist": "../src",
    "devUrl": null
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "companion",
        "title": "Companion",
        "url": "index.html",
        "width": 340,
        "height": 220,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "acceptFirstMouse": true,
        "hiddenTitle": true
      },
      {
        "label": "settings",
        "title": "Companion — Settings",
        "url": "settings/index.html",
        "width": 720,
        "height": 560,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "focus": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
